{
  "stryker-config": {
    "project": "src/ParentalControlsApp/ParentalControlsApp.csproj",
    "test-projects": [
      "tests/ParentalControlsApp.Tests/ParentalControlsApp.Tests.csproj"
    ],
    "reporters": ["html", "progress", "cleartext"],
    "thresholds": {
      "high": 90,
      "low": 75,
      "break": 60
    },
    "mutate": [
      "src/ParentalControlsApp/Services/**/*.cs",
      "src/ParentalControlsApp/Models/**/*.cs",
      "!src/ParentalControlsApp/App.cs"
    ],
    "ignore-mutations": [
      "string",
      "linq"
    ],
    "concurrency": 4
  }
}
