{
  "stryker-config": {
    "project": "src/ContentFilter/ContentFilter.csproj",
    "test-projects": [
      "tests/ContentFilter.Tests/ContentFilter.Tests.csproj"
    ],
    "reporters": ["html", "progress", "cleartext"],
    "thresholds": {
      "high": 90,
      "low": 75,
      "break": 60
    },
    "mutate": [
      "src/ContentFilter/Services/**/*.cs",
      "src/ContentFilter/Models/**/*.cs",
      "!src/ContentFilter/App.cs"
    ],
    "ignore-mutations": [
      "string",
      "linq"
    ],
    "concurrency": 4
  }
}
